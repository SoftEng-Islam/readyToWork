meta {
  name: List Orders
  type: http
  seq: 1
  tags: [
    current
    orders
  ]
}

get {
  url: {{apiUrl}}/orders
  body: none
  auth: none
}

tests {
  test('orders returns 200', function () {
    expect(res.getStatus()).to.equal(200);
  });

  test('orders returns a list', function () {
    const body = res.getBody();

    expect(body).to.be.an('array');
    expect(body.length).to.be.greaterThan(0);
    expect(body[0]).to.have.property('status');
  });
}
