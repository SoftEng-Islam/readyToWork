}

post {
  url: {{apiUrl}}/auth/register
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "name": "{{customerName}}",
    "email": "{{customerEmail}}",
    "password": "{{customerPassword}}"
  }
}
