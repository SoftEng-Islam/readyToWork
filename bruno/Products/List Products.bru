meta {
  name: List Products
  type: http
  seq: 1
  tags: [
    current
    smoke
    products
  ]
}

get {
  url: {{apiUrl}}/products
  body: none
  auth: none
}

tests {
  test('product list returns 200', function () {
    expect(res.getStatus()).to.equal(200);
  });

  test('product list returns an array', function () {
    const body = res.getBody();

    expect(body).to.be.an('array');
    expect(body.length).to.be.greaterThan(0);
    expect(body[0]).to.have.property('slug');
  });
}
