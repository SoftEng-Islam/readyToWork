meta {
  name: Create Review
  type: http
  seq: 2
  tags: [
    planned
    contract
    reviews
  ]
}

post {
  url: {{apiUrl}}/products/{{productSlug}}/reviews
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  content-type: application/json
}

body:json {
  {
    "rating": 5,
    "title": "Great product",
    "comment": "Works well for daily use."
  }
}
