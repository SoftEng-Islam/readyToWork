{
  "name": "modern-vue-express-ecommerce-starter",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "description": "Modern Vue 3 + Express e-commerce starter with TypeScript, Drizzle, Better Auth, and Tailwind.",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@parcel/watcher",
      "argon2",
      "esbuild",
      "vue-demi"
    ]
  },
  "keywords": [
    "vue",
    "express",
    "graphql",
    "ecommerce",
    "marketplace",
    "shop",
    "drizzle-orm",
    "better-auth",
    "pinia",
    "tailwindcss",
    "typescript"
  ],
  "scripts": {
    "dev": "tsx watch src/server/main.ts",
    "dev:server": "tsx watch src/server/main.ts",
    "build": "vue-tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit && vite build",
    "preview": "pnpm build && NODE_ENV=production tsx src/server/main.ts",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "check": "pnpm lint && pnpm type-check && pnpm test:run && pnpm build",
    "type-check": "vue-tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:setup": "sh ./doctor.sh",
    "scaffold": "sh ./create-project.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ruru": "node ./scripts/ruru.mjs"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@formkit/auto-animate": "^0.9.0",
    "@graphql-tools/schema": "^10.0.31",
    "@heroicons/vue": "^2.2.0",
    "@remixicon/vue": "^4.9.0",
    "@vue/apollo-composable": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "animate.css": "^4.1.1",
    "argon2": "^0.44.0",
    "axios": "^1.14.0",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "graphql": "^16.13.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "ruru": "2.0.0",
    "stripe": "^21.0.1",
    "tippy.js": "^6.3.7",
    "tsx": "^4.21.0",
    "vee-validate": "^4.15.1",
    "vite-express": "^0.22.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "vue-toastification": "2.0.0-rc.5",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/compiler-sfc": "^3.5.31",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "~10.8.0",
    "happy-dom": "^20.8.9",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-svg-loader": "^5.1.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "vue-tippy": "^6.7.1",
    "vue-tsc": "^3.2.6"
  }
}
