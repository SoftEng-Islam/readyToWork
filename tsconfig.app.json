{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": [
    "src/client/**/*.ts",
    "src/client/**/*.d.ts",
    "src/client/**/*.vue",
    "src/shared/**/*.ts",
    "src/shared/**/*.d.ts"
  ],
  "exclude": ["src/server/**/*"]
}
